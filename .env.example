# Form Memory URL (Supabase Edge Function base — no trailing slash)
# Local: http://127.0.0.1:54321/functions/v1/form-memory
# Production: https://YOUR_PROJECT_REF.supabase.co/functions/v1/form-memory
FORM_MEMORY_URL=http://127.0.0.1:54321/functions/v1/form-memory

# Platform API key — run: npm run key:generate
FORM_MEMORY_API_KEY=fm_live_replace_me

# Personal workspace (default seeded in migration)
FORM_MEMORY_WORKSPACE_ID=00000000-0000-4000-8000-000000000001

# Supabase CLI local (auto-set when using supabase start)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
